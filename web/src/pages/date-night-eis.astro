---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShopGrid from '../components/ShopGrid.astro';
import LeafletMap from '../components/LeafletMap.astro';
import { getDateNightShops, resolveShopPhotoMap } from '../lib/data';
import { Moon, ArrowLeft } from 'lucide-astro';

const shops = await getDateNightShops();
const photoMap = await resolveShopPhotoMap(shops);
---

<BaseLayout title="Date Night Eis in Leipzig — Romantische Eisdielen" description="Romantische Eisdielen für den perfekten Abend in Leipzig: Geöffnet nach 20 Uhr, mit Atmosphäre und gutem Eis.">
  <section class="max-w-[960px] mx-auto px-4 py-8">
    <div class="mb-2">
      <a href="/" class="text-sm text-blueberry hover:text-choco transition-colors inline-flex items-center gap-1">
        <ArrowLeft size={14} stroke-width={2} /> Alle Eisdielen
      </a>
    </div>
    <div class="mb-8 animate-fade-up">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-blueberry-bg mb-4">
        <Moon size={24} stroke-width={2} class="text-blueberry" />
      </div>
      <h1 class="font-heading text-3xl sm:text-4xl font-semibold text-choco mb-4">
        Zwei Kugeln, ein Abend, Leipzig
      </h1>
      <p class="text-lg text-choco-light leading-relaxed max-w-2xl">
        Manchmal braucht man keinen Drei-Gänge-Abend, sondern nur den richtigen Ort und gutes Eis.
      </p>
    </div>

    <div class="mb-10">
      <LeafletMap shops={shops} height="300px" id="date-map" />
    </div>

    <ShopGrid shops={shops} photoMap={photoMap} emptyMessage="Keine Abend-Eisdielen gefunden." />
  </section>
</BaseLayout>
