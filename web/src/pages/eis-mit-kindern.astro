---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShopGrid from '../components/ShopGrid.astro';
import LeafletMap from '../components/LeafletMap.astro';
import { getKidFriendlyShops, resolveShopPhotoMap } from '../lib/data';
import { Baby, ArrowLeft } from 'lucide-astro';

const shops = await getKidFriendlyShops();
const photoMap = await resolveShopPhotoMap(shops);
---

<BaseLayout title="Eis mit Kindern in Leipzig — Familienfreundliche Eisdielen" description="Die besten familienfreundlichen Eisdielen in Leipzig: kurze Wartezeiten, Spielplätze in der Nähe und kleine Portionen.">
  <section class="max-w-[960px] mx-auto px-4 py-8">
    <div class="mb-2">
      <a href="/" class="text-sm text-blueberry hover:text-choco transition-colors inline-flex items-center gap-1">
        <ArrowLeft size={14} stroke-width={2} /> Alle Eisdielen
      </a>
    </div>
    <div class="mb-8 animate-fade-up">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-mango-bg mb-4">
        <Baby size={24} stroke-width={2} class="text-mango" />
      </div>
      <h1 class="font-heading text-3xl sm:text-4xl font-semibold text-choco mb-4">
        Eis essen mit der ganzen Bande
      </h1>
      <p class="text-lg text-choco-light leading-relaxed max-w-2xl">
        Kleine Portionen, kurze Schlange, Platz für den Kinderwagen — und am besten noch eine Bank draußen, auf der alle sitzen können. Hier findest du Eisdielen, die wirklich familienfreundlich sind.
      </p>
    </div>

    <div class="mb-10">
      <LeafletMap shops={shops} height="300px" id="kids-map" />
    </div>

    <ShopGrid shops={shops} photoMap={photoMap} emptyMessage="Keine kinderfreundlichen Eisdielen gefunden." />
  </section>
</BaseLayout>
