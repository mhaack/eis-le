---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeafletMap from '../components/LeafletMap.astro';
import ShopCard from '../components/ShopCard.astro';
import { getAllShops, resolveShopPhotoMap } from '../lib/data';

const shops = await getAllShops();
const photoMap = await resolveShopPhotoMap(shops);
---

<BaseLayout title="Eiskarte Leipzig — Alle Eisdielen auf der Karte" description="Finde Eisdielen in deiner Nähe auf der interaktiven Leipzig-Karte.">
  <div class="max-w-[1200px] mx-auto px-4 py-8">
    <h1 class="font-heading text-3xl sm:text-4xl font-semibold text-schoko mb-6">
      Eiskarte Leipzig
    </h1>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
      <!-- Map (3/5 width on desktop, full on mobile) -->
      <div class="lg:col-span-3 lg:sticky lg:top-20 lg:self-start">
        <LeafletMap shops={shops} height="500px" />
      </div>

      <!-- Shop list (2/5 width on desktop) -->
      <div class="lg:col-span-2 space-y-4">
        <p class="text-sm text-schoko-muted font-medium">
          {shops.length} Eisdielen in Leipzig
        </p>
        {shops.map((shop, i) => (
          <ShopCard shop={shop} index={i} photoUrl={photoMap.get(shop.id)} />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
