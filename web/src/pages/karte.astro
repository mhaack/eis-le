---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeafletMap from '../components/LeafletMap.astro';
import ShopCard from '../components/ShopCard.astro';
import { getAllShops, resolveShopPhotoMap } from '../lib/data';

const shops = await getAllShops();
const photoMap = await resolveShopPhotoMap(shops);
---

<BaseLayout title="Eiskarte Leipzig — Alle Eisdielen auf der Karte" description="Finde Eisdielen in deiner Nähe auf der interaktiven Leipzig-Karte.">
  <div class="page-wrap">
    <div class="page-head">
      <h1 class="page-title">Eiskarte <em>Leipzig</em></h1>
      <p class="page-count">{shops.length} Eisdielen</p>
    </div>

    <div class="map-layout">
      <div class="map-col">
        <LeafletMap shops={shops} height="560px" />
      </div>

      <div class="list-col">
        {shops.map((shop, i) => (
          <ShopCard shop={shop} photoUrl={photoMap.get(shop.id)} />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 1rem 80px;
  }

  .page-head {
    margin-bottom: 28px;
  }

  .page-title {
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: clamp(28px, 5vw, 42px);
    color: var(--color-choco);
    letter-spacing: -0.01em;
    margin: 0 0 4px;
  }

  .page-title em {
    font-style: italic;
    color: var(--color-pistachio);
  }

  .page-count {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0;
  }

  .map-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 24px;
    align-items: start;
  }

  .map-col {
    position: sticky;
    top: 80px;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    overflow: hidden;
  }

  .list-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  @media (max-width: 900px) {
    .map-layout {
      grid-template-columns: 1fr;
    }

    .map-col {
      position: static;
    }
  }
</style>
