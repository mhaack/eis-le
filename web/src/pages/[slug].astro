---
import BaseLayout from '../layouts/BaseLayout.astro';
import LVZBadge from '../components/LVZBadge.astro';
import Tag from '../components/Tag.astro';
import FlavorList from '../components/FlavorList.astro';
import HighlightList from '../components/HighlightList.astro';
import RatingCTA from '../components/RatingCTA.astro';
import { getAllShops, getShopBySlug, formatOpeningHours, resolveShopPhotos } from '../lib/data';
import { Star, ArrowLeft, Clock, MapPin, Phone, ExternalLink, Navigation, CreditCard, IceCreamCone, Sparkles } from 'lucide-astro';

export async function getStaticPaths() {
  const shops = await getAllShops();
  return shops.map(shop => ({
    params: { slug: shop.slug },
  }));
}

const { slug } = Astro.params;
const shop = await getShopBySlug(slug!);

if (!shop) {
  return Astro.redirect('/');
}

const stars = Math.round(shop.google_rating);
const photos = await resolveShopPhotos(shop.photos);

// Build tags
const tags: { label: string; variant: 'pistachio' | 'strawberry' | 'vanilla' | 'blueberry' | 'mango' | 'default' }[] = [];
if (shop.has_vegan_options) tags.push({ label: shop.fully_vegan ? 'Voll vegan' : 'Vegane Optionen', variant: 'pistachio' });
if (shop.child_friendly) tags.push({ label: 'Kinderfreundlich', variant: 'mango' });
if (shop.has_bike_parking) tags.push({ label: 'Fahrradstellplatz', variant: 'default' });
if (shop.is_organic) tags.push({ label: 'Bio', variant: 'pistachio' });
if (shop.has_lactose_free) tags.push({ label: 'Laktosefrei', variant: 'pistachio' });
if (shop.has_gluten_free) tags.push({ label: 'Glutenfrei', variant: 'pistachio' });
if (shop.has_outdoor_seating) tags.push({ label: 'Terrasse', variant: 'default' });
if (shop.has_coffee) tags.push({ label: 'Kaffee', variant: 'default' });

const hoursEntries = formatOpeningHours(shop.opening_hours);
const editorialText = shop.our_review ?? shop.specialty ?? null;
const tempClosed = shop.google_business_status === 'CLOSED_TEMPORARILY';
---

<BaseLayout title={`${shop.name} — Eisdiele in ${shop.neighborhood?.name ?? 'Leipzig'}, Leipzig`} description={shop.specialty} canonical={`https://eis-le.de/${shop.slug}`} image={photos[0]}>
  <article class="max-w-[960px] mx-auto px-4 py-6">
    <!-- Back nav -->
    <div class="mb-4">
      <a href="/" class="text-sm text-blueberry hover:text-choco transition-colors inline-flex items-center gap-1">
        <ArrowLeft size={14} stroke-width={2} /> Alle Eisdielen
      </a>
    </div>

    <!-- Hero image -->
    <div class="relative rounded-[20px] overflow-hidden h-64 sm:h-80 mb-6 animate-fade-up">
      <img
        src={photos[0]}
        alt={shop.name}
        class:list={['w-full h-full object-cover', tempClosed && 'grayscale']}
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/10 to-transparent" />

      {shop.lvz_rank && (
        <div class="absolute top-4 left-4">
          <LVZBadge rank={shop.lvz_rank} size="lg" />
        </div>
      )}

      <div class="absolute bottom-4 left-4 right-4">
        <p class="text-white/80 text-sm font-medium mb-1">{shop.ice_cream_type}</p>
        <h1 class="font-heading text-2xl sm:text-3xl font-bold text-white">{shop.name}</h1>
      </div>
    </div>

    <!-- Info bar -->
    <div class="card p-4 mb-6 animate-fade-up stagger-1">
      <div class="flex flex-wrap items-center gap-4 sm:gap-6 text-sm">
        <!-- Rating -->
        <div class="flex items-center gap-1.5">
          <div class="flex gap-0.5">
            {Array.from({ length: 5 }).map((_, i) => (
              <Star size={16} stroke-width={2} class:list={[i < stars ? 'text-vanilla fill-current' : 'text-border']} />
            ))}
          </div>
          <span class="font-semibold text-choco">{shop.google_rating}</span>
          <span class="text-choco-muted">({shop.google_review_count})</span>
        </div>
        <!-- Neighborhood -->
        {shop.neighborhood && (
          <a href={`/stadtteil/${shop.neighborhood.slug}`} class="text-blueberry font-medium hover:underline inline-flex items-center gap-1">
            <MapPin size={14} stroke-width={2} />
            {shop.neighborhood.name}
          </a>
        )}
        <!-- Price -->
        {shop.price_per_scoop && (
          <span class="text-choco-muted">{shop.price_per_scoop}/Kugel</span>
        )}
        <!-- Open status -->
        {tempClosed ? (
          <span class="pill text-xs font-medium bg-strawberry-bg text-strawberry">
            Vorübergehend geschlossen
          </span>
        ) : shop.is_24h ? (
          <span class="pill text-xs font-medium bg-pistachio-bg text-pistachio">
            24h geöffnet
          </span>
        ) : shop.opening_hours && (shop.opening_hours as unknown[]).length > 0 && (
          <span
            class="pill text-xs font-medium hidden"
            data-open-status
            data-periods={JSON.stringify(shop.opening_hours)}
          />
        )}
      </div>
    </div>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-6 animate-fade-up stagger-2">
        {tags.map(t => <Tag label={t.label} variant={t.variant} size="md" />)}
      </div>
    )}

    <!-- Editorial intro -->
    {editorialText && (
      <div class="mb-8 animate-fade-up stagger-2">
        <p class="text-lg text-choco-light leading-relaxed">
          {editorialText}
        </p>
      </div>
    )}

    <!-- Two-column content -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
      <!-- Left: Flavors -->
      <div class="animate-fade-up stagger-3">
        <h2 class="font-heading text-xl font-semibold text-choco mb-4 flex items-center gap-2">
          <IceCreamCone size={20} stroke-width={2} class="text-strawberry" /> Eissorten
        </h2>
        <FlavorList flavors={shop.flavor_list ?? []} />
      </div>

      <!-- Right: Highlights -->
      <div class="animate-fade-up stagger-4">
        <h2 class="font-heading text-xl font-semibold text-choco mb-4 flex items-center gap-2">
          <Sparkles size={20} stroke-width={2} class="text-vanilla" /> Das Besondere hier
        </h2>
        <HighlightList highlights={shop.highlights ?? []} />
      </div>
    </div>

    <!-- Details section -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
      <!-- Opening hours -->
      <div class="card p-5 animate-fade-up stagger-5 flex flex-col">
        <h3 class="font-heading text-lg font-semibold text-choco mb-3 flex items-center gap-2">
          <Clock size={18} stroke-width={2} class="text-choco-muted" /> Öffnungszeiten
        </h3>
        {tempClosed && (
          <div class="rounded-xl bg-strawberry-bg px-3 py-2 mb-3">
            <p class="text-sm font-medium text-strawberry">Vorübergehend geschlossen</p>
          </div>
        )}
        {shop.is_24h && !tempClosed && (
          <div class="rounded-xl bg-pistachio-bg px-3 py-2 mb-3">
            <p class="text-sm font-medium text-pistachio">24 Stunden geöffnet, 7 Tage die Woche</p>
          </div>
        )}
        <div class="space-y-2 flex-1">
          {hoursEntries.map(([day, hours]) => (
            <div class="flex justify-between text-sm">
              <span class="text-choco-muted">{day}</span>
              <span class="font-medium text-choco">{hours}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Location & contact -->
      <div class="card p-5 animate-fade-up stagger-6 flex flex-col">
        <h3 class="font-heading text-lg font-semibold text-choco mb-3 flex items-center gap-2">
          <MapPin size={18} stroke-width={2} class="text-choco-muted" /> Anfahrt & Kontakt
        </h3>
        <div class="space-y-2.5 text-sm flex-1">
          <p class="text-choco">{shop.address}</p>
          {shop.location_description && (
            <p class="text-choco-muted italic">{shop.location_description}</p>
          )}
          {shop.phone && (
            <p>
              <a href={`tel:${shop.phone}`} class="text-blueberry inline-flex items-center gap-1.5">
                <Phone size={14} stroke-width={2} /> {shop.phone}
              </a>
            </p>
          )}
          {shop.website && (
            <p>
              <a href={shop.website} target="_blank" rel="noopener" class="text-blueberry inline-flex items-center gap-1.5">
                <ExternalLink size={14} stroke-width={2} /> Website besuchen
              </a>
            </p>
          )}
          <p>
            <a href={shop.google_maps_url} target="_blank" rel="noopener" class="text-blueberry inline-flex items-center gap-1.5">
              <Navigation size={14} stroke-width={2} /> Auf Google Maps
            </a>
          </p>
          {shop.payment_methods?.length > 0 && (
            <p class="text-choco-muted inline-flex items-center gap-1.5">
              <CreditCard size={14} stroke-width={2} /> {shop.payment_methods.join(', ')}
            </p>
          )}
        </div>
      </div>
    </div>

    <!-- Rating CTA -->
    <div class="mb-10 animate-fade-up stagger-7">
      <RatingCTA shopName={shop.name} />
    </div>
  </article>
</BaseLayout>

<script>
  import { renderAllOpenStatusPills } from '../scripts/open-status';
  renderAllOpenStatusPills();
</script>
