---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShopGrid from '../../components/ShopGrid.astro';
import LeafletMap from '../../components/LeafletMap.astro';
import NeighborhoodPills from '../../components/NeighborhoodPills.astro';
import { ArrowLeft } from 'lucide-astro';
import { getShopsByNeighborhood, getNeighborhoods, resolveShopPhotoMap } from '../../lib/data';

export async function getStaticPaths() {
  const neighborhoods = await getNeighborhoods();
  return neighborhoods.map(n => ({
    params: { slug: n.slug },
    props: {
      name: n.name,
      latitude: n.latitude,
      longitude: n.longitude,
      description: n.description,
      short_description: n.short_description,
    },
  }));
}

const { slug } = Astro.params;
const { name, latitude, longitude, description, short_description } = Astro.props;
const center = latitude && longitude ? { lat: latitude, lng: longitude } : null;
const shops = await getShopsByNeighborhood(slug!);
const photoMap = await resolveShopPhotoMap(shops);
const allNeighborhoods = await getNeighborhoods();
const hasOtherNeighborhoods = allNeighborhoods.some(n => n.slug !== slug);
---

<BaseLayout title={`Eisdielen in ${name} — Leipzig`} description={short_description ?? `Die besten Eisdielen in ${name}, Leipzig. Finde dein Eis im Viertel.`} canonical={`https://eis-le.de/stadtteil/${slug}`} image={shops[0] ? photoMap.get(shops[0].id) : undefined}>
  <section class="max-w-[960px] mx-auto px-4 py-8">
    <div class="mb-2">
      <a href="/stadtteile" class="text-sm text-blueberry hover:text-choco transition-colors inline-flex items-center gap-1">
        <ArrowLeft size={14} stroke-width={2} /> Alle Stadtteile
      </a>
    </div>

    <div class="mb-8 animate-fade-up">
      <h1 class="font-heading text-3xl sm:text-4xl font-semibold text-choco mb-2">
        Eisdielen in {name}
      </h1>
      <p class="text-lg text-choco-muted mb-4">
        {shops.length} {shops.length === 1 ? 'Eisdiele' : 'Eisdielen'} in {name}
      </p>
      {description && (
        <p class="text-lg text-choco-light leading-relaxed max-w-2xl">
          {description}
        </p>
      )}
    </div>

    {shops.length > 0 && (
      <div class="mb-10">
        <LeafletMap shops={shops} height="300px" id={`map-${slug}`} center={center} />
      </div>
    )}

    <ShopGrid shops={shops} photoMap={photoMap} emptyMessage={`Noch keine Eisdielen in ${name} erfasst.`} />

    {hasOtherNeighborhoods && (
      <div class="mt-16 pt-10 border-t border-border">
        <h2 class="font-heading text-xl font-semibold text-choco mb-5 text-center">
          Eis in anderen Stadtteilen
        </h2>
        <NeighborhoodPills neighborhoods={allNeighborhoods} excludeSlug={slug} ariaLabel="Andere Stadtteile" />
      </div>
    )}
  </section>
</BaseLayout>
