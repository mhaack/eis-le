---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShopGrid from '../../components/ShopGrid.astro';
import LeafletMap from '../../components/LeafletMap.astro';
import { getShopsByNeighborhood, getNeighborhoods, resolveShopPhotoMap } from '../../lib/data';

export async function getStaticPaths() {
  const neighborhoods = await getNeighborhoods();
  return neighborhoods.map(n => ({
    params: { slug: n.slug },
    props: { name: n.name, latitude: n.latitude, longitude: n.longitude },
  }));
}

const { slug } = Astro.params;
const { name, latitude, longitude } = Astro.props;
const center = latitude && longitude ? { lat: latitude, lng: longitude } : null;
const shops = await getShopsByNeighborhood(slug!);
const photoMap = await resolveShopPhotoMap(shops);
---

<BaseLayout title={`Eisdielen in ${name} — Leipzig`} description={`Die besten Eisdielen in ${name}, Leipzig. Finde dein Eis im Viertel.`}>
  <section class="max-w-[960px] mx-auto px-4 py-8">
    <div class="mb-2">
      <a href="/" class="text-sm text-heidelbeere hover:text-schoko transition-colors">
        ← Alle Eisdielen
      </a>
    </div>

    <div class="mb-8 animate-fade-up">
      <h1 class="font-heading text-3xl sm:text-4xl font-semibold text-schoko mb-2">
        Eisdielen in {name}
      </h1>
      <p class="text-lg text-schoko-muted">
        {shops.length} {shops.length === 1 ? 'Eisdiele' : 'Eisdielen'} in {name}
      </p>
    </div>

    {shops.length > 0 && (
      <div class="mb-10">
        <LeafletMap shops={shops} height="300px" id={`map-${slug}`} center={center} />
      </div>
    )}

    <ShopGrid shops={shops} photoMap={photoMap} emptyMessage={`Noch keine Eisdielen in ${name} erfasst.`} />
  </section>
</BaseLayout>
