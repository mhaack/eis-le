---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FilterBar from '../components/FilterBar.astro';
import ShopCard from '../components/ShopCard.astro';
import { IceCreamCone } from 'lucide-astro';
import { getAllShops, resolveShopPhotoMap } from '../lib/data';

const shops = await getAllShops();
const photoMap = await resolveShopPhotoMap(shops);

const neighborhoodCount = new Set(shops.map(s => s.neighborhood_id).filter(Boolean)).size;
---

<BaseLayout title="eisleipzig — Die besten Eisdielen in Leipzig">
  <Hero shopCount={shops.length} neighborhoodCount={neighborhoodCount} />

  <div x-data="shopFilter()" x-cloak>
    <FilterBar />

    <div class="page-wrap">
      <!-- All stores -->
      <div class="section-meta">
        <h2 class="section-title">Alle <em>Eisdielen</em></h2>
        <span class="section-sub" x-text={`\`— zeige \${visibleCount >= 0 ? visibleCount : ${shops.length}} von ${shops.length}\``}>— zeige {shops.length} von {shops.length}</span>
      </div>

      <div
        :class="activeView === 'list' ? 'store-list' : 'store-grid'"
        x-ref="grid"
      >
        {shops.map((shop, i) => (
          <div
            class="shop-card-wrapper"
            data-periods={JSON.stringify(shop.opening_hours ?? [])}
            data-name={shop.name}
            data-rating={shop.google_rating ?? 0}
            data-filter-lvz={shop.lvz_rank ? 'true' : undefined}
            data-filter-vegan={shop.has_vegan_options ? 'true' : undefined}
            data-filter-bio={shop.is_organic ? 'true' : undefined}
            data-filter-kinder={shop.child_friendly ? 'true' : undefined}
            data-filter-outdoor={shop.has_outdoor_seating ? 'true' : undefined}
            data-filter-spät={shop.open_after_8pm ? 'true' : undefined}
            data-filter-handgemacht={shop.is_handmade ? 'true' : undefined}
            data-temp-closed={shop.google_business_status === 'CLOSED_TEMPORARILY' ? 'true' : undefined}
            data-is-24h={shop.is_24h ? 'true' : undefined}
            data-search={`${shop.name} ${shop.neighborhood?.name ?? ''} ${shop.specialty ?? ''} ${shop.ice_cream_type ?? ''}`.toLowerCase()}
          >
            <ShopCard shop={shop} photoUrl={photoMap.get(shop.id)} />
          </div>
        ))}
      </div>

      <div x-show="visibleCount === 0" class="empty-state" x-cloak>
        <IceCreamCone size={28} stroke-width={2} class="empty-icon" />
        <p>Hmm, hier schmilzt gerade nichts. Versuch&rsquo;s mit weniger Filtern.</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1rem 80px;
  }

  .section-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 36px 0 20px;
  }

  .section-title {
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: 26px;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--color-choco);
  }

  .section-title em {
    font-style: italic;
    color: var(--color-pistachio);
  }

  .section-sub {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }

  /* Store grid */
  .store-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    padding-bottom: 24px;
  }

  /* Store list */
  .store-list {
    display: flex;
    flex-direction: column;
    padding-bottom: 24px;
    border-top: 1px solid var(--rule);
  }

  .store-list .shop-card-wrapper {
    border-bottom: 1px solid var(--rule-soft);
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 64px 0;
    color: var(--color-choco-muted);
    font-family: var(--font-heading);
    font-size: 18px;
    font-style: italic;
  }

  .empty-icon {
    display: block;
    margin: 0 auto 12px;
    color: var(--color-choco-muted);
  }

  @media (max-width: 720px) {
    .store-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .store-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  import { isOpenNow } from '../scripts/open-status';

  document.addEventListener('alpine:init', () => {
    window.Alpine.data('shopFilter', () => ({
      activeFilters: new Set(),
      activeSort: 'name',
      activeView: 'grid',
      searchQuery: '',
      visibleCount: -1,

      init() {
        const ttl = 24 * 60 * 60 * 1000;
        ['eis-sort', 'eis-view'].forEach(key => {
          const stored = localStorage.getItem(key);
          if (!stored) return;
          try {
            const { value, expires } = JSON.parse(stored);
            if (expires > Date.now()) {
              if (key === 'eis-sort') this.activeSort = value;
              if (key === 'eis-view') this.activeView = value;
            } else {
              localStorage.removeItem(key);
            }
          } catch { localStorage.removeItem(key); }
        });

        this.applySort();
        this.updateOpenStat();
      },

      toggleFilter(key: string) {
        if (key === 'alle') {
          this.activeFilters.clear();
        } else {
          if (this.activeFilters.has(key)) this.activeFilters.delete(key);
          else this.activeFilters.add(key);
        }
        this.applyFilter();
      },

      clearFilters() {
        this.activeFilters.clear();
        this.applyFilter();
      },

      setView(v: string) {
        this.activeView = v;
        localStorage.setItem('eis-view', JSON.stringify({ value: v, expires: Date.now() + 24 * 60 * 60 * 1000 }));
      },

      applySearch() {
        this.applyFilter();
      },

      applySort() {
        const grid = this.$refs.grid;
        const cards = [...grid.querySelectorAll('.shop-card-wrapper')];
        if (this.activeSort === 'name') {
          cards.sort((a, b) => a.dataset.name.localeCompare(b.dataset.name, 'de'));
        } else if (this.activeSort === 'rating') {
          cards.sort((a, b) => parseFloat(b.dataset.rating) - parseFloat(a.dataset.rating));
        }
        cards.forEach(card => grid.appendChild(card));
        this.applyFilter();
        localStorage.setItem('eis-sort', JSON.stringify({ value: this.activeSort, expires: Date.now() + 24 * 60 * 60 * 1000 }));
      },

      applyFilter() {
        const cards = this.$refs.grid.querySelectorAll('.shop-card-wrapper');
        let count = 0;
        cards.forEach((card: Element) => {
          const el = card;
          let show = true;

          // Search
          if (this.searchQuery.trim()) {
            const hay = el.dataset.search || '';
            if (!hay.includes(this.searchQuery.toLowerCase().trim())) show = false;
          }

          // Active filters
          if (show) {
            for (const key of this.activeFilters) {
              if (key === 'open') {
                if (el.hasAttribute('data-temp-closed')) { show = false; break; }
                if (el.hasAttribute('data-is-24h')) continue;
                try {
                  const periods = JSON.parse(el.dataset.periods || '[]');
                  if (!isOpenNow(periods)) { show = false; break; }
                } catch { show = false; break; }
              } else {
                if (!el.hasAttribute(`data-filter-${key}`)) { show = false; break; }
              }
            }
          }

          el.style.display = show ? '' : 'none';
          if (show) count++;
        });
        this.visibleCount = count;
      },

      updateOpenStat() {
        const cards = document.querySelectorAll('.shop-card-wrapper');
        let openCount = 0;
        cards.forEach(card => {
          const el = card;
          if (el.hasAttribute('data-temp-closed')) return;
          if (el.hasAttribute('data-is-24h')) { openCount++; return; }
          try {
            const periods = JSON.parse(el.dataset.periods || '[]');
            if (isOpenNow(periods)) openCount++;
          } catch { /* skip */ }
        });
        const statEl = document.getElementById('stat-open');
        if (statEl) statEl.textContent = String(openCount);
      },
    }));
  });
</script>
