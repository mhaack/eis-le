---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import UserStoryPills from '../components/UserStoryPills.astro';
import FilterBar from '../components/FilterBar.astro';
import ShopCard from '../components/ShopCard.astro';
import { IceCreamCone } from 'lucide-astro';
import { getAllShops, resolveShopPhotoMap } from '../lib/data';

const shops = await getAllShops();
const photoMap = await resolveShopPhotoMap(shops);
---

<BaseLayout title="eisleipzig — Die besten Eisdielen in Leipzig">
  <Hero />
  <UserStoryPills />
  <div x-data="shopFilter()" x-cloak>
    <FilterBar />
    <section class="max-w-[960px] mx-auto px-4 pb-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" x-ref="grid">
        {shops.map((shop, i) => (
          <div
            class="shop-card-wrapper"
            data-periods={JSON.stringify(shop.opening_hours ?? [])}
            data-name={shop.name}
            data-rating={shop.google_rating ?? 0}
            data-filter-lvz={shop.lvz_rank ? 'true' : undefined}
            data-filter-vegan={shop.has_vegan_options ? 'true' : undefined}
            data-filter-bio={shop.is_organic ? 'true' : undefined}
            data-filter-kinder={shop.child_friendly ? 'true' : undefined}
            data-temp-closed={shop.google_business_status === 'CLOSED_TEMPORARILY' ? 'true' : undefined}
            data-is-24h={shop.is_24h ? 'true' : undefined}
          >
            <ShopCard shop={shop} index={i} photoUrl={photoMap.get(shop.id)} />
          </div>
        ))}
      </div>
      <div x-show="visibleCount === 0" class="text-center py-16" x-cloak>
        <p class="text-xl mb-2"><IceCreamCone size={28} stroke-width={2} class="text-choco-muted mx-auto" /></p>
        <p class="text-choco-muted font-heading text-lg">Hmm, hier schmilzt gerade nichts. Versuch's mit weniger Filtern.</p>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  import { isOpenNow } from '../scripts/open-status';

  document.addEventListener('alpine:init', () => {
    window.Alpine.data('shopFilter', () => ({
      activeFilter: 'alle',
      activeSort: 'name',
      visibleCount: -1,
      init() {
        const ttl = 24 * 60 * 60 * 1000;
        ['eis-sort', 'eis-filter'].forEach(key => {
          const stored = localStorage.getItem(key);
          if (!stored) return;
          try {
            const { value, expires } = JSON.parse(stored);
            if (expires > Date.now()) {
              if (key === 'eis-sort') this.activeSort = value;
              else this.activeFilter = value;
            } else {
              localStorage.removeItem(key);
            }
          } catch { localStorage.removeItem(key); }
        });
        this.applySort();
        this.$watch('activeFilter', () => {
          localStorage.setItem('eis-filter', JSON.stringify({
            value: this.activeFilter,
            expires: Date.now() + ttl,
          }));
          this.applyFilter();
        });
        this.$watch('activeSort', () => {
          localStorage.setItem('eis-sort', JSON.stringify({
            value: this.activeSort,
            expires: Date.now() + ttl,
          }));
          this.applySort();
        });
      },
      applySort() {
        const grid = this.$refs.grid;
        const cards = [...grid.querySelectorAll('.shop-card-wrapper')];
        if (this.activeSort === 'name') {
          cards.sort((a, b) => a.dataset.name.localeCompare(b.dataset.name, 'de'));
        } else if (this.activeSort === 'rating') {
          cards.sort((a, b) => parseFloat(b.dataset.rating) - parseFloat(a.dataset.rating));
        }
        cards.forEach(card => grid.appendChild(card));
        this.applyFilter();
      },
      applyFilter() {
        const cards = this.$refs.grid.querySelectorAll('.shop-card-wrapper');
        let count = 0;
        cards.forEach(card => {
          let show = false;
          if (this.activeFilter === 'alle') {
            show = true;
          } else if (this.activeFilter === 'open') {
            if (card.hasAttribute('data-temp-closed')) {
              show = false;
            } else if (card.hasAttribute('data-is-24h')) {
              show = true;
            } else {
              try {
                const periods = JSON.parse(card.dataset.periods || '[]');
                show = isOpenNow(periods);
              } catch { show = false; }
            }
          } else {
            show = card.hasAttribute(`data-filter-${this.activeFilter}`);
          }
          card.style.display = show ? '' : 'none';
          if (show) count++;
        });
        this.visibleCount = count;
      }
    }));
  });
</script>
