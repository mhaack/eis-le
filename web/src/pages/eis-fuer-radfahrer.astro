---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShopGrid from '../components/ShopGrid.astro';
import LeafletMap from '../components/LeafletMap.astro';
import { getBikeFriendlyShops, resolveShopPhotoMap } from '../lib/data';
import { Bike } from 'lucide-astro';

const shops = await getBikeFriendlyShops();
const photoMap = await resolveShopPhotoMap(shops);
---

<BaseLayout title="Eis für Radfahrer in Leipzig — Fahrradfreundliche Eisdielen" description="Fahrradfreundliche Eisdielen in Leipzig: Mit Fahrradstellplätzen, an Radwegen und perfekt für eine Eispause auf der Tour.">
  <section class="max-w-[960px] mx-auto px-4 py-8">
    <div class="mb-8 animate-fade-up">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-sand mb-4">
        <Bike size={24} stroke-width={2} class="text-choco-muted" />
      </div>
      <h1 class="font-heading text-3xl sm:text-4xl font-semibold text-choco mb-4">
        Klingel ab, Kugel auf
      </h1>
      <p class="text-lg text-choco-light leading-relaxed max-w-2xl">
        Leipzig ist eine Fahrradstadt — und die besten Eispausen liegen dort, wo die schönsten Radwege entlangführen.
      </p>
    </div>

    <div class="mb-10">
      <LeafletMap shops={shops} height="300px" id="bike-map" />
    </div>

    <ShopGrid shops={shops} photoMap={photoMap} emptyMessage="Keine fahrradfreundlichen Eisdielen gefunden." />
  </section>
</BaseLayout>
