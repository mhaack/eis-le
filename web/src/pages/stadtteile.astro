---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getNeighborhoods } from '../lib/data';

const neighborhoods = await getNeighborhoods();
---

<BaseLayout title="Eisdielen in Leipzigs Stadtteilen" description="Entdecke die besten Eisdielen in Leipzig nach Stadtteil: Connewitz, Südvorstadt, Plagwitz, Gohlis und mehr." canonical="https://eis-le.de/stadtteile">
  <div class="page-wrap">
    <a href="/" class="back-link">← Alle Eisdielen</a>

    <div class="page-head">
      <h1 class="page-title">Stadtteile <em>in Leipzig</em></h1>
      <p class="page-sub">Von Connewitz bis Gohlis, von Plagwitz bis zur Südvorstadt — Eis in jedem Viertel.</p>
    </div>

    {neighborhoods.length > 0 ? (
      <div class="hood-grid">
        {neighborhoods.map(n => (
          <a href={`/stadtteil/${n.slug}`} class="hood-card">
            <div class="hood-count">{n.count} {n.count === 1 ? 'Eisdiele' : 'Eisdielen'}</div>
            <h2 class="hood-name">{n.name}</h2>
            {(n.short_description ?? n.description) && (
              <p class="hood-desc">{n.short_description ?? n.description}</p>
            )}
            <span class="hood-arrow">→</span>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty">Noch keine Stadtteile erfasst.</p>
    )}
  </div>
</BaseLayout>

<style>
  .page-wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 40px 1rem 80px;
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 28px;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--color-choco); }

  .page-head {
    margin-bottom: 40px;
  }

  .page-title {
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: clamp(28px, 5vw, 42px);
    color: var(--color-choco);
    margin: 0 0 10px;
    letter-spacing: -0.01em;
  }

  .page-title em {
    font-style: italic;
    color: var(--color-pistachio);
  }

  .page-sub {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 17px;
    color: var(--ink-soft);
    margin: 0;
    max-width: 52ch;
  }

  .hood-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .hood-card {
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 20px 22px 22px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .hood-card:hover {
    border-color: var(--color-pistachio);
    transform: translateY(-2px);
    box-shadow: 0 12px 28px -16px oklch(0.4 0.05 80 / 0.2);
  }

  .hood-count {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 4px;
  }

  .hood-name {
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: 22px;
    letter-spacing: -0.01em;
    color: var(--color-choco);
    margin: 0 0 8px;
  }

  .hood-desc {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 13px;
    color: var(--ink-soft);
    margin: 0;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .hood-arrow {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-mute);
    margin-top: 14px;
    display: block;
    transition: color 0.15s;
  }

  .hood-card:hover .hood-arrow { color: var(--color-pistachio); }

  .empty {
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--ink-mute);
    font-size: 16px;
  }

  @media (max-width: 720px) {
    .hood-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 640px) {
    .hood-grid { grid-template-columns: 1fr; }
  }
</style>
