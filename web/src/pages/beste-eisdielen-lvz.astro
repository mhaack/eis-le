---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShopGrid from '../components/ShopGrid.astro';
import LeafletMap from '../components/LeafletMap.astro';
import { getLVZShops, resolveShopPhotoMap } from '../lib/data';

const shops = await getLVZShops();
const photoMap = await resolveShopPhotoMap(shops);
---

<BaseLayout title="Beste Eisdielen Leipzig 2025 — LVZ-Ranking" description="Das LVZ-Ranking der beliebtesten Eisdielen in Leipzig 2025: Platz 1 bis 5, mit allen Details.">
  <section class="max-w-[960px] mx-auto px-4 py-8">
    <div class="mb-8 animate-fade-up">
      <span class="text-4xl mb-4 block">🏆</span>
      <h1 class="font-heading text-3xl sm:text-4xl font-semibold text-schoko mb-4">
        Leipzig hat gewählt — das sind die Besten
      </h1>
      <p class="text-lg text-schoko-light leading-relaxed max-w-2xl">
        Jeden Sommer kürt die LVZ die beliebtesten Eisdielen der Stadt. Hier sind sie, mit allen Details.
      </p>
    </div>

    <div class="mb-10">
      <LeafletMap shops={shops} height="300px" id="lvz-map" />
    </div>

    <ShopGrid shops={shops} photoMap={photoMap} emptyMessage="Noch kein LVZ-Ranking vorhanden." />
  </section>
</BaseLayout>
