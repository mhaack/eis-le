---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Entdecken' },
  { href: '/karte', label: 'Karte' },
  // { href: '/beste-eisdielen-lvz', label: 'LVZ-Ranking' },
];
---

<header class="sticky top-0 z-50 bg-creme/90 backdrop-blur-md border-b border-border">
  <nav class="max-w-[960px] mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 no-underline group">
      <span class="text-2xl">🍦</span>
      <span class="font-heading text-xl font-semibold text-schoko group-hover:text-erdbeere transition-colors">
        eisleipzig
      </span>
    </a>
    <div class="hidden sm:flex items-center gap-6">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium transition-colors',
            currentPath === link.href
              ? 'text-schoko'
              : 'text-schoko-muted hover:text-schoko',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
    <!-- Mobile menu button -->
    <button
      class="sm:hidden p-2 text-schoko-muted hover:text-schoko"
      aria-label="Menü öffnen"
      x-data
      @click="$dispatch('toggle-mobile-nav')"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
  <!-- Mobile nav -->
  <div
    x-data="{ open: false }"
    @toggle-mobile-nav.window="open = !open"
    x-show="open"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-2"
    class="sm:hidden border-b border-border bg-creme px-4 pb-4"
    style="display: none;"
  >
    <div class="flex flex-col gap-3">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium py-1',
            currentPath === link.href
              ? 'text-schoko'
              : 'text-schoko-muted hover:text-schoko',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>
