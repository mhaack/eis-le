---
import LogoIcon from './LogoIcon.astro';

const currentPath = Astro.url.pathname;

const entdeckenLinks = [
  { href: '/',                  label: 'Alle Eisdielen' },
  { href: '/stadtteile',        label: 'Stadtteile' },
  { href: '/veganes-eis',       label: 'Veganes Eis' },
  { href: '/eis-mit-kindern',   label: 'Eis mit Kindern' },
  { href: '/date-night-eis',    label: 'Date Night' },
  { href: '/eis-fuer-radfahrer',label: 'Radtour-Stopp' },
];

const topLinks = [
  { href: '/karte',      label: 'Karte' },
  { href: '/stadtteile', label: 'Stadtteile' },
];

const entdeckenPaths = new Set(['/', '/veganes-eis', '/eis-mit-kindern', '/date-night-eis', '/eis-fuer-radfahrer']);
const isEntdeckenActive =
  entdeckenPaths.has(currentPath) ||
  currentPath.startsWith('/stadtteil/') ||
  currentPath.startsWith('/shop/');

function isActive(href: string): boolean {
  if (currentPath === href) return true;
  if (href === '/stadtteile' && currentPath.startsWith('/stadtteil/')) return true;
  return false;
}
---

<header class="nav-bar">
  <nav class="nav-inner">
    <!-- Logo — DO NOT CHANGE -->
    <a href="/" class="flex items-center gap-0 no-underline leading-none" aria-label="eis-le.de — Startseite">
      <span class="font-heading text-[1.3rem] font-bold text-choco tracking-[0.02em]">E</span>
      <LogoIcon size={22} class="relative -top-px -mx-px shrink-0" />
      <span class="font-heading text-[1.3rem] font-bold text-choco tracking-[0.02em]">S</span>
      <span class="font-heading text-[1.15rem] font-normal text-choco-muted mx-[0.3rem] tracking-[0.04em]">//</span>
      <span class="font-heading text-[1.3rem] font-normal text-choco-muted tracking-[0.06em]">LE</span>
    </a>

    <div class="nav-links">
      <!-- Entdecken dropdown -->
      <div x-data="{ open: false }" class="nav-dropdown-wrap" @click.outside="open = false" @keydown.escape.window="open = false">
        <button
          class:list={['nav-link nav-dropdown-btn', isEntdeckenActive && 'active']}
          @click="open = !open"
          :aria-expanded="open"
          aria-haspopup="true"
        >
          Entdecken
          <svg class="nav-chevron" :class="open && 'rotated'" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
            <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div x-show="open" x-cloak x-transition:enter="dropdown-enter" x-transition:enter-start="dropdown-enter-start" x-transition:enter-end="dropdown-enter-end" x-transition:leave="dropdown-leave" x-transition:leave-start="dropdown-leave-start" x-transition:leave-end="dropdown-leave-end" class="nav-dropdown" @click="open = false">
          {entdeckenLinks.map(link => (
            <a href={link.href} class:list={['nav-dropdown-link', isActive(link.href) && 'active']}>
              {link.label}
            </a>
          ))}
        </div>
      </div>

      {topLinks.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', isActive(link.href) && 'active']}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile menu button -->
    <button
      class="nav-mobile-btn sm:hidden"
      aria-label="Menü öffnen"
      x-data
      @click="$dispatch('toggle-mobile-nav')"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile nav -->
  <div
    x-data="{ open: false }"
    @toggle-mobile-nav.window="open = !open"
    x-show="open"
    x-transition:enter="transition ease-out duration-150"
    x-transition:enter-start="opacity-0 -translate-y-1"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-100"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-1"
    class="nav-mobile-drawer sm:hidden"
    style="display: none;"
  >
    {entdeckenLinks.map(link => (
      <a href={link.href} class:list={['nav-mobile-link', isActive(link.href) && 'active']}>
        {link.label}
      </a>
    ))}
    <div class="nav-mobile-divider"></div>
    {topLinks.map(link => (
      <a href={link.href} class:list={['nav-mobile-link', isActive(link.href) && 'active']}>
        {link.label}
      </a>
    ))}
  </div>
</header>

<style>
  .nav-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: var(--color-creme);
    border-bottom: 1px solid var(--rule);
  }

  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 16px 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .nav-links { display: flex; }
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-choco);
  }

  /* Dropdown */
  .nav-dropdown-wrap {
    position: relative;
  }

  .nav-dropdown-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .nav-chevron {
    transition: transform 0.15s;
    color: var(--ink-mute);
  }

  .nav-chevron.rotated {
    transform: rotate(180deg);
  }

  .nav-dropdown {
    position: absolute;
    top: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-creme);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 6px 0;
    min-width: 160px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    z-index: 100;
  }

  .nav-dropdown-link {
    display: block;
    padding: 8px 16px;
    font-family: var(--font-body);
    font-size: 13.5px;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.1s, background 0.1s;
    white-space: nowrap;
  }

  .nav-dropdown-link:hover,
  .nav-dropdown-link.active {
    color: var(--color-choco);
    background: var(--color-card-bg);
  }

  /* Mobile */
  .nav-mobile-btn {
    background: none;
    border: none;
    color: var(--ink-soft);
    cursor: pointer;
    padding: 1px 4px;
  }

  .nav-mobile-drawer {
    border-top: 1px solid var(--rule-soft);
    padding: 12px 1rem 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .nav-mobile-link {
    font-family: var(--font-body);
    font-size: 17px;
    color: var(--ink-soft);
    text-decoration: none;
    padding: 4px 0;
  }

  .nav-mobile-link.active {
    color: var(--color-choco);
  }

  .nav-mobile-divider {
    border-top: 1px solid var(--rule-soft);
    margin: 4px 0;
  }
</style>
