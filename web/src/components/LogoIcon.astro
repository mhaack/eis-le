---
interface Props {
  size?: number;
  class?: string;
}

const { size = 24, class: className = '' } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
>
  <!-- Cone -->
  <path d="M8 11l4 11 4-11" fill="var(--color-vanille, #EDD07A)" stroke="var(--color-schoko, #2D1B10)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
  <!-- Scoop top (Erdbeere) -->
  <circle cx="12" cy="8" r="4" fill="var(--color-erdbeere, #DC6B7E)" stroke="var(--color-schoko, #2D1B10)" stroke-width="1.5" />
  <!-- Scoop left (Pistazie) -->
  <circle cx="8.5" cy="10" r="3" fill="var(--color-pistazie, #94B87A)" stroke="var(--color-schoko, #2D1B10)" stroke-width="1.5" />
  <!-- Scoop right (Vanille) -->
  <circle cx="15.5" cy="10" r="3" fill="var(--color-vanille-bg, #FBF0D4)" stroke="var(--color-schoko, #2D1B10)" stroke-width="1.5" />
</svg>
