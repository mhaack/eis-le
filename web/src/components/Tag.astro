---
interface Props {
  label: string;
  variant?: 'pistachio' | 'strawberry' | 'vanilla' | 'blueberry' | 'mango' | 'default';
  size?: 'sm' | 'md';
}

const { label, variant = 'default', size = 'sm' } = Astro.props;

const variantClasses: Record<string, string> = {
  pistachio: 'bg-pistachio-bg text-pistachio',
  strawberry: 'bg-strawberry-bg text-strawberry',
  vanilla: 'bg-vanilla-bg text-vanilla',
  blueberry: 'bg-blueberry-bg text-blueberry',
  mango: 'bg-mango-bg text-mango',
  default: 'bg-sand text-choco-muted',
};

const sizeClasses: Record<string, string> = {
  sm: 'text-xs px-2.5 py-0.5',
  md: 'text-sm px-3 py-1',
};
---

<span class:list={['pill', variantClasses[variant], sizeClasses[size]]}>
  {label}
</span>
