---
import LogoIcon from './LogoIcon.astro';
import { getNeighborhoods } from '../lib/data';

const neighborhoods = await getNeighborhoods();
---

<footer class="bg-choco text-creme/80 mt-16">
  <div class="max-w-[960px] mx-auto px-4 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-0 text-creme no-underline mb-3 leading-none">
          <span class="font-heading text-xl font-bold tracking-[0.02em]">E</span>
          <LogoIcon size={22} class="relative -top-px -mx-px shrink-0" />
          <span class="font-heading text-xl font-bold tracking-[0.02em]">S</span>
          <span class="font-heading text-[1.1rem] font-normal opacity-50 mx-[0.3rem] tracking-[0.04em]">//</span>
          <span class="font-heading text-xl font-normal opacity-50 tracking-[0.06em]">LE</span>
        </a>
        <p class="text-sm text-creme/60 leading-relaxed">
          Alle Eisdielen in Leipzig.<br />
          Ehrlich bewertet, liebevoll kuratiert.
        </p>
      </div>
      <!-- Entdecken -->
      <div>
        <h4 class="font-heading text-sm font-semibold text-creme mb-3 uppercase tracking-wider">Entdecken</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/veganes-eis" class="text-creme/60 hover:text-creme transition-colors">Veganes Eis</a></li>
          <li><a href="/eis-mit-kindern" class="text-creme/60 hover:text-creme transition-colors">Eis mit Kindern</a></li>
          <li><a href="/date-night-eis" class="text-creme/60 hover:text-creme transition-colors">Date Night</a></li>
          <li><a href="/eis-fuer-radfahrer" class="text-creme/60 hover:text-creme transition-colors">Radtour-Stopp</a></li>
        </ul>
      </div>
      <!-- Stadtteile (two columns) -->
      <div class="sm:col-span-2">
        <h4 class="font-heading text-sm font-semibold text-creme mb-3 uppercase tracking-wider">
          <a href="/stadtteile" class="text-creme hover:text-creme/80 transition-colors">Stadtteile</a>
        </h4>
        <ul class="grid grid-cols-2 gap-x-6 gap-y-2 text-sm">
          {neighborhoods.map(n => (
            <li>
              <a href={`/stadtteil/${n.slug}`} class="text-creme/60 hover:text-creme transition-colors">
                {n.name} <span class="opacity-50 text-xs ml-0.5">{n.count}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class="border-t border-creme/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-creme/40 font-heading italic">
        Gemacht in Leipzig, mit Liebe und zu viel Eis.
      </p>
      <div class="flex items-center gap-4 text-xs">
        <a href="/impressum" class="text-creme/50 hover:text-creme transition-colors">Impressum</a>
        <a href="/datenschutz" class="text-creme/50 hover:text-creme transition-colors">Datenschutz</a>
        <span>&copy; {new Date().getFullYear()} eis-le.de</span>
      </div>
    </div>
  </div>
</footer>
