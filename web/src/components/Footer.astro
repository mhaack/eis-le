---
import LogoIcon from './LogoIcon.astro';
import { getNeighborhoods } from '../lib/data';

const neighborhoods = await getNeighborhoods();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand-col">
        <!-- Logo — DO NOT CHANGE -->
        <a href="/" class="footer-logo flex items-center gap-0 no-underline leading-none" aria-label="eis-le.de">
          <span class="font-heading text-xl font-bold tracking-[0.02em]">E</span>
          <LogoIcon size={22} class="relative -top-px -mx-px shrink-0" />
          <span class="font-heading text-xl font-bold tracking-[0.02em]">S</span>
          <span class="font-heading text-[1.1rem] font-normal opacity-50 mx-[0.3rem] tracking-[0.04em]">//</span>
          <span class="font-heading text-xl font-normal opacity-50 tracking-[0.06em]">LE</span>
        </a>
        <p class="footer-blurb">
          Alle Eisdielen der Stadt — ehrlich bewertet, liebevoll kuratiert, mit Geheimtipps und Lieblingsorten.
        </p>
      </div>

      <!-- Entdecken + Mehr -->
      <div class="footer-nav-col">
        <div class="footer-col">
          <h5 class="footer-col-head">Entdecken</h5>
          <a href="/">Alle Eisdielen</a>
          <a href="/stadtteile">Stadtteile</a>
          <a href="/veganes-eis">Veganes Eis</a>
          <a href="/eis-mit-kindern">Eis mit Kindern</a>
          <a href="/date-night-eis">Date Night</a>
          <a href="/eis-fuer-radfahrer">Radtour-Stopp</a>
        </div>
        <div class="footer-col">
          <h5 class="footer-col-head">Mehr</h5>
          <a href="/karte">Karte</a>
          <a href="/impressum">Impressum</a>
          <a href="/datenschutz">Datenschutz</a>
        </div>
      </div>

      <!-- Stadtteile -->
      <div class="footer-col">
        <h5 class="footer-col-head"><a href="/stadtteile">Stadtteile</a></h5>
        <div class="footer-stadtteile-links">
          {neighborhoods.map(n => (
            <a href={`/stadtteil/${n.slug}`}>
              {n.name} <span class="footer-count">{n.count}</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="footer-foot">
      <span>© {new Date().getFullYear()} eis-le.de, Leipzig</span>
      <span class="footer-tagline">Gemacht in Leipzig, mit Liebe und zu viel Eis.</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--rule);
    margin-top: 48px;
    padding: 52px 0 40px;
    background: var(--color-creme);
  }

  .footer-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 3fr;
    gap: 40px;
    margin-bottom: 48px;
  }

  .footer-nav-col {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .footer-logo {
    color: var(--color-choco);
    margin-bottom: 14px;
  }

  .footer-blurb {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 14.5px;
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 0;
    max-width: 34ch;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-col-head {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 6px;
    font-weight: 500;
  }

  .footer-col .footer-col-head a {
    color: inherit;
    text-decoration: none;
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: inherit;
  }

  .footer-stadtteile-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px 16px;
  }

  .footer-col a {
    font-size: 13.5px;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-col a:hover {
    color: var(--color-pistachio);
  }

  .footer-count {
    font-family: var(--font-mono);
    font-size: 9.5px;
    color: var(--ink-mute);
    margin-left: 3px;
  }

  .footer-foot {
    border-top: 1px solid var(--rule-soft);
    padding-top: 22px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }

  .footer-tagline {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 13px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--ink-soft);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
    .footer-brand-col {
      grid-column: 1 / -1;
    }
    .footer-stadtteile-links {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-stadtteile-links {
      grid-template-columns: 1fr;
    }
    .footer-foot {
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }
  }
</style>
