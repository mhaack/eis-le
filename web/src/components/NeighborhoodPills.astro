---
import type { Neighborhood } from '../lib/data';

interface Props {
  neighborhoods: Neighborhood[];
  excludeSlug?: string;
  ariaLabel?: string;
}

const { neighborhoods, excludeSlug, ariaLabel = 'Stadtteile' } = Astro.props;

const visible = excludeSlug
  ? neighborhoods.filter(n => n.slug !== excludeSlug)
  : neighborhoods;
---

{visible.length > 0 && (
  <nav aria-label={ariaLabel}>
    <ul class="pills-list">
      {visible.map(n => (
        <li>
          <a href={`/stadtteil/${n.slug}`} class="pill">
            {n.name} <span class="pill-count">{n.count}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .pills-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .pill {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 6px 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: border-color 0.15s, color 0.15s;
  }

  .pill:hover {
    border-color: var(--color-pistachio);
    color: var(--color-choco);
  }

  .pill-count {
    color: var(--ink-mute);
    font-size: 9.5px;
  }
</style>
