---
import { Baby, Leaf, Moon, Bike, Trophy } from 'lucide-astro';

const stories = [
  { href: '/eis-mit-kindern', icon: Baby, label: 'Eis mit Kindern', variant: 'mango' },
  { href: '/veganes-eis', icon: Leaf, label: 'Veganes Eis', variant: 'pistachio' },
  { href: '/date-night-eis', icon: Moon, label: 'Date Night', variant: 'blueberry' },
  { href: '/eis-fuer-radfahrer', icon: Bike, label: 'Radtour-Stopp', variant: 'choco' },
];

//   { href: '/beste-eisdielen-lvz', icon: Trophy, label: 'Beste laut LVZ', variant: 'strawberry' },

const bgMap: Record<string, string> = {
  mango: 'bg-mango-bg text-mango hover:bg-mango/15',
  pistachio: 'bg-pistachio-bg text-pistachio hover:bg-pistachio/15',
  blueberry: 'bg-blueberry-bg text-blueberry hover:bg-blueberry/15',
  choco: 'bg-sand text-choco-light hover:bg-choco/10',
  strawberry: 'bg-strawberry-bg text-strawberry hover:bg-strawberry/15',
};
---

<section class="max-w-[960px] mx-auto px-4 pb-6">
  <div class="flex flex-wrap justify-center gap-2.5">
    {stories.map(s => (
      <a
        href={s.href}
        class:list={[
          'pill text-sm font-medium no-underline transition-colors inline-flex items-center gap-1.5',
          bgMap[s.variant],
        ]}
      >
        <s.icon size={14} stroke-width={2} />
        <span>{s.label}</span>
      </a>
    ))}
  </div>
</section>
