---
import { Star, Award, Truck, RefreshCw, Heart, Leaf, Sparkles, Coffee, MapPin, Clock, Gift, Smile, ThumbsUp, Zap, Sun, Snowflake, Music, Camera, Dog, Popsicle, Dessert, CupSoda, Vegan, CircleParking, Utensils, Cake } from 'lucide-astro';

interface Props {
  highlights: { icon: string; title: string; text: string }[];
}

const { highlights } = Astro.props;

const iconMap: Record<string, any> = {
  star: Star,
  award: Award,
  truck: Truck,
  'refresh-cw': RefreshCw,
  heart: Heart,
  leaf: Leaf,
  sparkles: Sparkles,
  coffee: Coffee,
  'map-pin': MapPin,
  clock: Clock,
  gift: Gift,
  smile: Smile,
  'thumbs-up': ThumbsUp,
  zap: Zap,
  sun: Sun,
  snowflake: Snowflake,
  music: Music,
  camera: Camera,
  dog: Dog,
  popsicle: Popsicle,
  dessert: Dessert,
  'cup-soda': CupSoda,
  vegan: Vegan,
  'circle-parking': CircleParking,
  utensils: Utensils,
  cake: Cake,
};
---

<div class="hl-list">
  {highlights.map(h => {
    const Icon = iconMap[h.icon];
    return (
      <div class="hl-item">
        <div class="hl-icon">
          {Icon ? <Icon size={16} stroke-width={2} /> : <span class="hl-emoji">{h.icon}</span>}
        </div>
        <div class="hl-body">
          <h4 class="hl-title">{h.title}</h4>
          <p class="hl-text">{h.text}</p>
        </div>
      </div>
    );
  })}
</div>

<style>
  .hl-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--rule);
    border-radius: 2px;
    overflow: hidden;
  }

  .hl-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 14px 16px;
    border-bottom: 1px solid var(--rule-soft);
  }

  .hl-item:last-child {
    border-bottom: none;
  }

  .hl-icon {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-strawberry);
  }

  .hl-emoji {
    font-size: 16px;
    line-height: 1;
  }

  .hl-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hl-title {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-choco);
    font-weight: 500;
    margin: 0;
  }

  .hl-text {
    font-family: var(--font-heading);
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.5;
    margin: 0;
  }
</style>
