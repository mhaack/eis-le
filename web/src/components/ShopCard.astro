---
import type { Shop } from '../lib/data';
import LVZBadge from './LVZBadge.astro';

interface Props {
  shop: Shop;
  photoUrl?: string;
}

const { shop, photoUrl } = Astro.props;

const tempClosed = shop.google_business_status === 'CLOSED_TEMPORARILY';

const tagLabels: string[] = [];
if (shop.has_vegan_options) tagLabels.push('Vegan');
if (shop.is_handmade) tagLabels.push('Handgemacht');
if (shop.has_outdoor_seating) tagLabels.push('Terrasse');
if (shop.child_friendly) tagLabels.push('Kinder');
if (shop.is_organic) tagLabels.push('Bio');
---

<a href={`/${shop.slug}`} class="shop-card">
  <!-- Art -->
  <div class="card-art">
    <img
      src={photoUrl || 'https://images.unsplash.com/photo-1501443762994-82bd5dace89a?w=600&h=400&fit=crop'}
      alt={shop.name}
      class:list={['card-photo', tempClosed && 'grayscale']}
      loading="lazy"
    />
{tempClosed ? (
      <span class="card-status closed">Geschlossen</span>
    ) : shop.is_24h ? (
      <span class="card-status open">24h</span>
    ) : shop.opening_hours && (shop.opening_hours as unknown[]).length > 0 && (
      <span
        class="card-status"
        style="display:none"
        data-open-status
        data-periods={JSON.stringify(shop.opening_hours)}
      />
    )}
    {shop.lvz_rank && (
      <div class="card-lvz-badge">
        <LVZBadge rank={shop.lvz_rank} size="sm" />
      </div>
    )}
  </div>

  <!-- Body -->
  <div class="card-body">
    <div class="card-hood">
      <span>{shop.neighborhood?.name ?? '—'}</span>
      {shop.price_per_scoop && <span>{shop.price_per_scoop}/Kugel</span>}
    </div>
    <h3 class="card-name">{shop.name}</h3>
    <p class="card-tagline">{shop.short_description || shop.specialty || shop.ice_cream_type}</p>
    {tagLabels.length > 0 && (
      <div class="card-tags">
        {tagLabels.slice(0, 3).map(t => <span class="card-tag">{t}</span>)}
      </div>
    )}
    <div class="card-meta">
      <span class="card-rating"><span class="card-star">★</span> {shop.google_rating?.toFixed(1)} <span class="card-dim">({shop.google_review_count})</span></span>
      <span>{shop.ice_cream_type}</span>
    </div>
  </div>
</a>

<style>
  .shop-card {
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }

  .shop-card:hover {
    border-color: var(--color-pistachio);
    transform: translateY(-2px);
    box-shadow: 0 16px 36px -20px oklch(0.4 0.05 80 / 0.25);
  }

  /* Art */
  .card-art {
    height: 160px;
    position: relative;
    overflow: hidden;
    background: var(--color-sand);
  }

  .card-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-status {
    position: absolute;
    top: 11px;
    right: 13px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 3px 7px;
    border-radius: 2px;
    background: oklch(0.99 0.008 85 / 0.9);
    color: var(--ink-soft);
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .card-status::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: oklch(0.62 0.02 60);
    flex-shrink: 0;
  }

  .card-status.open {
    color: oklch(0.42 0.1 140);
  }

  .card-status.open::before {
    background: oklch(0.72 0.14 140);
  }

  .card-status.closed {
    color: oklch(0.5 0.08 25);
  }

  .card-status.closed::before {
    background: oklch(0.65 0.1 25);
  }

  .card-lvz-badge {
    position: absolute;
    bottom: 11px;
    left: 13px;
  }

  /* Body */
  .card-body {
    padding: 15px 17px 17px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-hood {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 5px;
    display: flex;
    justify-content: space-between;
  }

  .card-name {
    font-family: var(--font-heading);
    font-size: 21px;
    letter-spacing: -0.01em;
    line-height: 1.05;
    margin: 0 0 3px;
    color: var(--color-choco);
    font-weight: 400;
  }

  .card-tagline {
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--ink-soft);
    font-size: 13px;
    margin: 0 0 11px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 4px;
  }

  .card-tag {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-pistachio);
    padding: 2px 6px;
    background: var(--color-pistachio-bg);
    border-radius: 2px;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--ink-mute);
    letter-spacing: 0.03em;
    padding-top: 10px;
    border-top: 1px solid var(--rule-soft);
    margin-top: auto;
  }

  .card-rating { color: var(--color-choco); }
  .card-star { color: var(--color-strawberry); }
  .card-dim { color: var(--ink-mute); }
</style>

<script>
  import { renderAllOpenStatusPills } from '../scripts/open-status';
  renderAllOpenStatusPills();
</script>
