---
import { type Shop } from '../lib/data';
import Tag from './Tag.astro';
import LVZBadge from './LVZBadge.astro';
import { Star } from 'lucide-astro';

interface Props {
  shop: Shop;
  index?: number;
  photoUrl?: string;
}

const { shop, index = 0, photoUrl } = Astro.props;

const stars = Math.round(shop.google_rating);
const tempClosed = shop.google_business_status === 'CLOSED_TEMPORARILY';

const tags: { label: string; variant: 'pistachio' | 'strawberry' | 'vanilla' | 'blueberry' | 'mango' | 'default' }[] = [];
if (shop.has_vegan_options) tags.push({ label: 'Vegan', variant: 'pistachio' });
if (shop.child_friendly) tags.push({ label: 'Kinderfreundlich', variant: 'mango' });
if (shop.has_bike_parking) tags.push({ label: 'Fahrrad', variant: 'default' });
---

<a
  href={`/${shop.slug}`}
  class:list={[
    'card block no-underline overflow-hidden animate-fade-up',
    `stagger-${(index % 9) + 1}`,
  ]}
  data-filter-lvz={shop.lvz_rank ? 'true' : undefined}
  data-filter-vegan={shop.has_vegan_options ? 'true' : undefined}
  data-filter-kinder={shop.child_friendly ? 'true' : undefined}
  data-filter-fahrrad={shop.has_bike_parking ? 'true' : undefined}
>
  <!-- Image -->
  <div class="relative h-48 overflow-hidden">
    <img
      src={photoUrl || 'https://images.unsplash.com/photo-1501443762994-82bd5dace89a?w=600&h=400&fit=crop'}
      alt={shop.name}
      class:list={['w-full h-full object-cover', tempClosed && 'grayscale']}
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent" />

    {shop.lvz_rank && (
      <div class="absolute top-3 left-3">
        <LVZBadge rank={shop.lvz_rank} size="sm" />
      </div>
    )}

    <div class="absolute top-3 right-3">
      {tempClosed ? (
        <span class="pill text-xs font-medium bg-strawberry-bg text-strawberry">
          Vorübergehend geschlossen
        </span>
      ) : shop.opening_hours && (shop.opening_hours as unknown[]).length > 0 && (
        <span
          class="pill text-xs font-medium hidden"
          data-open-status
          data-periods={JSON.stringify(shop.opening_hours)}
        />
      )}
    </div>
  </div>

  <!-- Content -->
  <div class="p-4">
    <!-- Neighborhood + rating row -->
    <div class="flex items-center justify-between mb-1.5">
      <span class="text-xs font-medium text-choco-muted uppercase tracking-wide">{shop.neighborhood?.name}</span>
      <div class="flex items-center gap-1">
        <Star size={14} stroke-width={2} class="text-vanilla fill-current" />
        <span class="text-sm font-semibold text-choco">{shop.google_rating}</span>
        <span class="text-xs text-choco-muted">({shop.google_review_count})</span>
      </div>
    </div>

    <!-- Shop name -->
    <h3 class="font-heading text-lg font-semibold text-choco mb-1 leading-snug">{shop.name}</h3>

    <!-- Type + price -->
    <p class="text-sm text-choco-muted mb-3">
      {shop.ice_cream_type}
      {shop.is_handmade && <span> · Handgemacht</span>}
      {shop.price_per_scoop && <span> · {shop.price_per_scoop}</span>}
    </p>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-3">
        {tags.map(t => <Tag label={t.label} variant={t.variant} />)}
      </div>
    )}

    <!-- Specialty quote -->
    {shop.specialty && (
      <p class="text-sm text-choco-light italic leading-relaxed line-clamp-2">
        &bdquo;{shop.specialty}&ldquo;
      </p>
    )}
  </div>
</a>

<script>
  import { renderAllOpenStatusPills } from '../scripts/open-status';
  renderAllOpenStatusPills();
</script>
