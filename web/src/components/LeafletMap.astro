---
import type { Shop } from '../lib/data';

interface Props {
  shops: Shop[];
  height?: string;
  id?: string;
}

const { shops, height = '400px', id = 'map' } = Astro.props;
const shopsJson = JSON.stringify(shops.map(s => ({
  id: s.id,
  name: s.name,
  slug: s.slug,
  lat: s.latitude,
  lng: s.longitude,
  lvz_rank: s.lvz_rank,
  neighborhood: s.neighborhood,
  rating: s.google_rating,
  type: s.ice_cream_type,
})));
---

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div id={id} style={`height: ${height}; border-radius: 16px;`} class="w-full border border-border"></div>

<script define:vars={{ shopsJson, mapId: id }}>
  async function initMap() {
    const L = await import('https://unpkg.com/leaflet@1.9.4/dist/leaflet-src.esm.js');
    const shops = JSON.parse(shopsJson);

    const map = L.map(mapId, {
      scrollWheelZoom: false,
    });

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 18,
    }).addTo(map);

    // Fit map to show all shop pins
    const validShops = shops.filter(s => s.lat && s.lng);
    if (validShops.length > 0) {
      const bounds = L.latLngBounds(validShops.map(s => [s.lat, s.lng]));
      map.fitBounds(bounds, { padding: [30, 30], maxZoom: 15 });
    } else {
      map.setView([51.3397, 12.3731], 13);
    }

    const pinColors = {
      1: '#d4a853',  // Gold
      2: '#b0b0b0',  // Silver
      3: '#cd7f32',  // Bronze
    };

    shops.forEach(shop => {
      const color = pinColors[shop.lvz_rank] || '#8b6f5e';
      const icon = L.divIcon({
        html: `<div style="
          width: 28px; height: 28px;
          background: ${color};
          border: 2.5px solid white;
          border-radius: 50%;
          box-shadow: 0 2px 6px rgba(45,24,16,0.25);
          display: flex; align-items: center; justify-content: center;
          font-size: 11px; font-weight: 700; color: white;
        ">${shop.lvz_rank ? '#' + shop.lvz_rank : '🍦'}</div>`,
        className: '',
        iconSize: [28, 28],
        iconAnchor: [14, 14],
      });

      const marker = L.marker([shop.lat, shop.lng], { icon }).addTo(map);
      marker.bindPopup(`
        <div style="font-family: 'DM Sans', sans-serif; min-width: 160px;">
          <strong style="font-size: 14px;">${shop.name}</strong><br/>
          <span style="color: #8b6f5e; font-size: 12px;">${shop.neighborhood} · ${shop.type}</span><br/>
          <span style="color: #c49a3c;">★</span> <span style="font-size: 13px;">${shop.rating}</span><br/>
          <a href="/${shop.slug}" style="color: #5b6da3; font-size: 12px; font-weight: 500;">Details ansehen →</a>
        </div>
      `);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
</script>
