---
import { Clock, Vegan, Baby, Sprout, ArrowDownAZ, Star, Moon, ChefHat } from 'lucide-astro';

const filters = [
  { key: 'alle',        label: 'Alle',             icon: null },
  { key: 'open',        label: 'Geöffnet',          icon: Clock },
  { key: 'handgemacht', label: 'Handgemacht',       icon: ChefHat },
  { key: 'bio',         label: 'Bio',               icon: Sprout },
  { key: 'vegan',       label: 'Vegan',             icon: Vegan },
  { key: 'kinder',      label: 'Kinderfreundlich',  icon: Baby },
  { key: 'spät',        label: 'Abends geöffnet',   icon: Moon },
];

const sorts = [
  { key: 'name',   label: 'A–Z',       icon: ArrowDownAZ },
  { key: 'rating', label: 'Bewertung', icon: Star },
];
---

<section class="controls-bar">
  <div class="controls-inner">
    <!-- Row 1: search + sort + view toggle -->
    <div class="controls-row">
      <div class="search-box">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.3"/>
          <path d="M11 11l3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
        </svg>
        <input
          type="search"
          placeholder="Name, Stadtteil, Sorte…"
          class="search-input"
          x-model="searchQuery"
          @input="applySearch()"
          @keydown.escape="searchQuery = ''; applySearch()"
        />
      </div>

      <div class="sort-group">
        <span class="sort-label">Sortierung</span>
        <select
          class="sort-select"
          x-model="activeSort"
          @change="applySort()"
        >
          {sorts.map(s => <option value={s.key}>{s.label}</option>)}
        </select>
      </div>

    </div>

    <!-- Row 2: filter chips -->
    <div class="filter-row">
      <span class="filter-label">Filter</span>
      <div class="chips-wrap">
        {filters.map(f => (
          <button
            class="chip"
            @click={`toggleFilter('${f.key}')`}
            :class={`activeFilters.has('${f.key}') ? 'active' : ''`}
          >
            {f.icon && <f.icon size={13} stroke-width={2} />}
            {f.label}
          </button>
        ))}
        <button class="chip-clear" @click="clearFilters()" x-show="activeFilters.size > 0" x-cloak>
          Zurücksetzen
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .controls-bar {
    border-bottom: 1px solid var(--rule);
    background: var(--color-creme);
    padding: 20px 0 18px;
    position: sticky;
    top: calc(55px + env(safe-area-inset-top, 0px));
    z-index: 30;
  }

  .controls-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .controls-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    align-items: center;
  }

  /* Search */
  .search-box {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 0 14px;
    height: 40px;
    color: var(--ink-mute);
  }

  .search-input {
    flex: 1;
    border: none;
    background: transparent;
    outline: none;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 15px;
    color: var(--color-choco);
    min-width: 0;
  }

  .search-input::placeholder {
    color: var(--ink-mute);
  }


  /* Sort */
  .sort-group {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mute);
    white-space: nowrap;
  }

  .sort-select {
    appearance: none;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 0 28px 0 12px;
    height: 40px;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-choco);
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'><path d='M1 1l4 4 4-4' stroke='%23666' fill='none' stroke-width='1.2'/></svg>");
    background-repeat: no-repeat;
    background-position: right 10px center;
    cursor: pointer;
  }

  /* View toggle */
  /* Filter row */
  .filter-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .filter-label {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-mute);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .chips-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 6px 13px;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-choco-muted);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .chip:hover {
    border-color: var(--color-pistachio);
    color: var(--color-choco);
  }

  .chip.active {
    background: var(--pistachio-ink);
    color: var(--color-creme);
    border-color: var(--pistachio-ink);
  }

  .chip-clear {
    background: transparent;
    border: none;
    color: var(--color-strawberry);
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    padding: 6px 10px;
  }

  @media (max-width: 640px) {
    .controls-row {
      grid-template-columns: 1fr auto;
    }
    .sort-group { display: none; }
    .filter-row {
      flex-direction: column;
      align-items: center;
    }
    .chips-wrap {
      justify-content: center;
    }
  }
</style>
