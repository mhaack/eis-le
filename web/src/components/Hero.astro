---
import { Trophy } from 'lucide-astro';
---

<section class="max-w-[960px] mx-auto px-4 pt-8 pb-6 text-center">
  <!-- Announcement badge -->
  <a
    href="/beste-eisdielen-lvz"
    class="inline-flex items-center gap-2 pill bg-erdbeere-bg text-erdbeere text-sm font-medium mb-6 hover:bg-erdbeere/10 transition-colors no-underline"
  >
    <Trophy size={16} stroke-width={2} />
    <span>LVZ-Rankings 2025 sind da</span>
    <span class="text-erdbeere/50">→</span>
  </a>

  <!-- Headline -->
  <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl font-700 text-schoko leading-tight mb-4">
    Finde dein Eis in{' '}
    <span class="wave-underline">Leipzig</span>
  </h1>

  <!-- Subtitle -->
  <p class="text-lg sm:text-xl text-schoko-light max-w-lg mx-auto leading-relaxed">
    Alle Eisdielen der Stadt — ehrlich bewertet, liebevoll kuratiert, mit Geheimtipps und Lieblingsorten.
  </p>
</section>
