# CF_PAGES_BRANCH is set automatically by Cloudflare Pages (e.g. "main").
# Google photo API calls are only made when CF_PAGES_BRANCH=main; branch previews
# and local dev get placehold.co images instead, saving API quota.
GOOGLE_PLACES_API_KEY=AIza...
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
CLAUDE_API_KEY=sk-ant-...
RESEND_API_KEY=re_...
ALERT_EMAIL=your-email@example.com
