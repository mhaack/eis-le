# Set to "production" on the main Cloudflare Pages build to enable Google photo resolution.
# Leave unset (or any other value) for branch previews and local dev — Google API calls are
# skipped and placehold.co images are used instead.
ENVIRONMENT=production
GOOGLE_PLACES_API_KEY=AIza...
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
CLAUDE_API_KEY=sk-ant-...
RESEND_API_KEY=re_...
ALERT_EMAIL=your-email@example.com
